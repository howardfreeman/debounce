{
  "compilerOptions": {
    /* Language & Environment */
    "target": "ES2020",
    "lib": ["ES2020"],
    "module": "commonjs",
    "moduleResolution": "node",

    /* Strictness */
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,

    /* Paths */
    "rootDir": ".",
    "outDir": "dist",

    /* Types */
    "types": ["jest", "node"],

    /* Quality of life */
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true
  },

  "include": ["**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
